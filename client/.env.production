# Production API base URL
# - If deploying client + server together on Vercel (same domain), leave empty
#   so it falls back to the relative /api path (handled by vercel.json rewrites)
# - If deploying backend separately (Render, Railway, etc.), set this to your
#   backend URL, e.g.: VITE_API_URL=https://recruit-pro-api.onrender.com/api
VITE_API_URL=
