PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/recruitpro?retryWrites=true&w=majority&appName=Cluster0
NODE_ENV=production
CRON_SECRET=replace-with-a-long-random-secret

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars
JWT_EXPIRE=7d

# Session Secret
SESSION_SECRET=your-session-secret-key-at-least-32-chars

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-backend-domain.com/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://your-backend-domain.com/api/auth/github/callback

# Frontend URL (your deployed client domain)
CLIENT_URL=https://your-frontend-domain.com

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
FROM_NAME=RecruitPro

# Email Service Configuration (for nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@recruitpro.com

# Google Calendar OAuth (uses same Client ID/Secret as Google login)
GOOGLE_REDIRECT_URI=https://your-backend-domain.com/api/calendar/callback

# Gemini AI
GEMINI_API_KEY=
